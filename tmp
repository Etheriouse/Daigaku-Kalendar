<!DOCTYPE html>
<html>


<head>
    <link rel="stylesheet" href="./style/light.css" id="style-light-theme">
    <link rel="stylesheet" href="./style/dark.css" id="style-dark-theme">
    <link rel="stylesheet" href="./style/nav-bar.css">
    <link rel="stylesheet" href="./style/burger.css">
    <link rel="stylesheet" href="./style/loader.css">
    <link rel="stylesheet" href="./style/month/event.css">
    <link rel="stylesheet" href="./style/month/week.css">
    <link rel="stylesheet" href="./style/month/month.css">
</head>

<body class="light">

    <style>
        body {
            margin: 0;
            overflow: hidden;
        }
    </style>
    <div id="burger-menu">
        <div id="nav-burger-menu">
            <p>Settings</p>
        </div>
        <div class="line"></div>
        <div id="list-type-schedule">
            <div class="type-schedule" data-id_type="month" id="type-schedule-selected">
                <span>🗓</span>
                <p>Mois</p>
            </div>
            <div class="type-schedule" data-id_type="week">
                <span>📅</span>
                <p>Semaine</p>
            </div>
            <div class="type-schedule" data-id_type="day">
                <span>🕑</span>
                <p>Jour</p>
            </div>
        </div>
    </div>

    <div id="app-content">
        <nav id="nav-bar">

            <div id="hidari-nav-bar">
                <span id="menu-span">
                    <svg width="30" height="30" viewBox="0 0 20 20">
                        <line x1="3" y1="2" x2="20" y2="2" stroke="white" stroke-width="2" />
                        <line x1="3" y1="10" x2="20" y2="10" stroke="white" stroke-width="2" />
                        <line x1="3" y1="18" x2="20" y2="18" stroke="white" stroke-width="2" />
                    </svg>
                </span>
            </div>

            <div id="migi-nav-bar">
                <span id="search-span">
                    <svg width="30" height="30" viewBox="0 0 25 25">
                        <circle cx="10" cy="10" r="8" stroke="white" stroke-width="2" fill="none" />
                        <line x1="16" y1="16" x2="23" y2="23" stroke="white" stroke-width="2" />
                    </svg>
                </span>
                <span id="today-span">
                    <p id="today-number">13</p>
                </span>

            </div>
        </nav>

        <div class="loading">
            <div class="loader"></div>
        </div>

        <section id="type-schedule-loaded" class="toload">
      
        </section>
    </div>

    <script type="module" src="./script/init.js"></script>
    <script type="module" src="./script/burger.js"></script>
    <!-- <script type="module" src="./event.js"></script>
    <script type="module" src="./swip.js"></script> -->
</body>

</html>