<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/WidgetMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@android:color/white">

    <!-- Message de chargement / aucun event -->
    <TextView
        android:id="@+id/NoneContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Chargement..."
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#000"
        android:visibility="visible" />

    <!-- Contenu événement -->
    <LinearLayout
        android:id="@+id/EventContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- Heure -->
        <TextView
            android:id="@+id/EventContentHour"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="top"
            android:layout_marginStart="12dp"
            android:paddingTop="4dp"
            android:text="9:45 - 11:15"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#000" />

        <!-- Infos event -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:id="@+id/EventContentTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PPAR TD"
                android:textStyle="bold"
                android:textColor="#000"
                android:textSize="15sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/EventContentLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="B12D - i-57 (008) -44"
                android:textSize="12sp"
                android:textColor="#555"
                android:maxLines="2"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/EventContentDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="B12D - i-57 (008) -44"
                android:textSize="12sp"
                android:textColor="#555"
                android:ellipsize="end"
                android:scrollHorizontally="false"
                android:breakStrategy="simple" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
